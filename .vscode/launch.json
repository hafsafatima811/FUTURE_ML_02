{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python 3.13: Flask",
            "type": "debugpy",
            "request": "launch",
            "module": "flask",
            "env": {
                "FLASK_APP": "app.py",
                "FLASK_DEBUG": "1"
            },
            "args": [
                "run",
                "--no-debugger",
                "--no-reload"
            ],
            "jinja": true,
            "justMyCode": true,
            "python": "${workspaceFolder}/venv/Scripts/python.exe"
        }
    ]
}
